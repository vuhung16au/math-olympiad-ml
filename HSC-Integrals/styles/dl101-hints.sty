\ProvidesPackage{dl101-hints}[2026/04/09 DL101 upside-down boxed hint style]

\RequirePackage{etoolbox}
\RequirePackage{rotating}
\RequirePackage{environ}
\RequirePackage[most]{tcolorbox}
\RequirePackage{xcolor}

% Use providecolor to avoid errors if colors aren't defined yet
\providecolor{bookpurple}{RGB}{60,16,83}
\providecolor{softivory}{RGB}{242,239,235}

\newtcolorbox{hintbox}{
  enhanced,
  colback=softivory,
  colframe=bookpurple,
  boxrule=1.2pt,
  arc=0pt,
  left=12pt,
  right=12pt,
  top=10pt,
  bottom=10pt,
  before skip=8pt,
  after skip=10pt,
}

% Define the hint environment (upside-down boxed style)
\NewEnviron{hint}[1][]{%
\par\noindent
\rotatebox[origin=c]{180}{%
\begin{minipage}{\linewidth}
\begin{hintbox}
\small
\ifstrempty{#1}{%
  \textbf{Hint:} %
}{%
  \textbf{Hint:} #1\ %
}%
\BODY
\end{hintbox}
\end{minipage}%
}%
\par
}
