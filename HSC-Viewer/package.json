{
  "name": "hsc-math-hub",
  "version": "1.0.0",
  "description": "HSC Mathematics Booklets Viewer - A Next.js app to view PDF booklets from HSC-Collections repository",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "thumbnails": "node scripts/generate-thumbnails.js",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "preview": "CLOUDFLARE_BUILD=1 opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "CLOUDFLARE_BUILD=1 opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "CLOUDFLARE_BUILD=1 opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@napi-rs/canvas": "^0.1.78",
    "lucide-react": "^0.344.0",
    "next": "16.2.6",
    "pdfjs-dist": "^4.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^9.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pdf2pic": "^2.2.0",
    "sharp": "^0.33.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.105.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@napi-rs/canvas",
    "sharp",
    "unrs-resolver"
  ]
}
