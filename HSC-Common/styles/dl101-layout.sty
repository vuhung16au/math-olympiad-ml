\ProvidesPackage{dl101-layout}[2025/10/20 DL101 fancy headers]
\RequirePackage{fancyhdr}
\RequirePackage{geometry}
\RequirePackage{extramarks}
\RequirePackage{url}

% Set in each booklet master file before loading this package, e.g.:
%   \newcommand{\HSCBookletHeaderTitle}{Probability}
\providecommand{\HSCBookletHeaderTitle}{HSC Booklet}

\geometry{
  a4paper,
  total={170mm,257mm},
  left=20mm,
  top=25mm,
  headheight=15pt,
  headsep=10pt,
  footskip=30pt
}

\pagestyle{fancy}
\fancyhf{}

\renewcommand{\sectionmark}[1]{\markboth{#1}{}\extramarks{}{}}
\ifdefined\chapter
  \renewcommand{\chaptermark}[1]{\markboth{#1}{}\extramarks{}{}}
\fi

\fancyhead[L]{\small\bfseries \HSCBookletHeaderTitle}
\fancyhead[R]{\small\itshape\leftmark\ifstrempty{\lastxmark}{}{ | \lastxmark}}

\fancyfoot[L]{\scriptsize\url{https://github.com/vuhung16au/math-olympiad-ml}}
\fancyfoot[C]{\small\thepage}
\fancyfoot[R]{\footnotesize Vu Hung Nguyen \(\cdot\) CC BY 4.0}

\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}

% HSC matte (cover/title) page typography.
% Reused across booklets for the consistent 3-line centered layout.
\newcommand{\HSCMatteTitleText}[3]{%
  % #1: course line, #2: topic line, #3: author
  \bfseries
  {\fontsize{26}{32}\selectfont #1\par}%
  \vspace{0.55cm}%
  {\fontsize{36}{44}\selectfont #2\par}%
  \vspace{0.55cm}%
  \noindent\raggedleft{\large #3\par}%
}

% Plain matte page (white background).
% Typesets the title block centered vertically on the current page.
\newcommand{\HSCMattePagePlain}[3]{%
  \thispagestyle{empty}%
  \vspace*{\fill}%
  \begin{center}%
    \begin{minipage}{0.92\textwidth}%
      \centering
      \HSCMatteTitleText{#1}{#2}{#3}%
    \end{minipage}%
  \end{center}%
  \vspace*{\fill}%
}
